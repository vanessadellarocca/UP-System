if __name__ == "__main__":
    backend = LLMBackend()
    up = UPSystem(backend, sit_config={})

    while True:
        try:
            text = input("Du: ").strip()
        except (EOFError, KeyboardInterrupt):
            print("\nUP: Beende Dialog.")
            break

        if not text:
            continue
        if text.lower() in {"exit", "quit", "ende"}:
            print("UP: Beende Dialog.")
            break

        print("UP:", up.process(text))

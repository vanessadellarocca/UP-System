import json
import uuid
from dataclasses import dataclass, field
from typing import Any, Dict, List, Optional

import requests


# ============================================================
# 1) DATATYPES
# ============================================================

@dataclass
class Entity:
    entity_id: str
    label: str


@dataclass
class Claim:
    text: str
    status: str = "observed"
    confidence: float = 1.0


@dataclass
class Articulation:
    subject_id: str
    predicate: str
    value: str
    dynamic_role: str = "neutral"
    modality: str = "open"
    scope: str = "local"
    channel: str = "outer"
    aspect: str = "neutral"
    confidence: float = 1.0


@dataclass
class Role:
    role_name: str
    confidence: float = 1.0


@dataclass
class Perspective:
    perspective_name: str
    confidence: float = 1.0


@dataclass
class Identity:
    name: Optional[str] = None
    mode: Optional[str] = None
    confidence: float = 1.0


@dataclass
class PerspectiveFrame:
    roles: List[Role] = field(default_factory=list)
    perspectives: List[Perspective] = field(default_factory=list)
    identities: List[Identity] = field(default_factory=list)


@dataclass
class ArticulationFrame:
    entities: List[Entity] = field(default_factory=list)
    claims: List[Claim] = field(default_factory=list)
    articulations: List[Articulation] = field(default_factory=list)
    perspective_frame: Optional[PerspectiveFrame] = None


@dataclass
class MarginState:
    m1_consistency: float = 1.0
    m2_dao: float = 1.0
    m3_identity: float = 1.0
    s_tension: float = 0.0


@dataclass
class SITGateResult:
    admissible: bool
    contradiction_score: float = 0.0
    meaning_shift_score: float = 0.0
    dao_violation_score: float = 0.0
    identity_drift_score: float = 0.0
    violations: List[str] = field(default_factory=list)
    margins: MarginState = field(default_factory=MarginState)


@dataclass
class UOLocalState:
    fixierungsarbeit: float = 0.0
    rueckkopplung: float = 0.0
    kohaerenz: float = 0.0
    attraktor: str = "kipppunkt"
    dynamik_resonanz: float = 0.0
    mikro_makro_resonanz: float = 0.0
    innen_aussen_resonanz: float = 0.0
    licht_schatten_balance: float = 0.5


@dataclass
class CoherenceMode:
    raw_text: str
    response_draft: Optional[str] = None
    assumptions: List[str] = field(default_factory=list)
    action_plan: Optional[Dict[str, Any]] = None
    update_proposal: Optional[Dict[str, Any]] = None
    frame: Optional[ArticulationFrame] = None
    gate_result: Optional[SITGateResult] = None
    uo_state: Optional[UOLocalState] = None
    integration_mode: Optional[str] = None
    strategic_score: float = 0.0
    probability_score: float = 0.0
    perspective_coverage_score: float = 0.0


@dataclass
class SystemState:
    input_articulation: Optional[ArticulationFrame] = None
    active_perspectives: PerspectiveFrame = field(default_factory=PerspectiveFrame)
    history: List[CoherenceMode] = field(default_factory=list)
    meta: Dict[str, Any] = field(default_factory=dict)


# ============================================================
# 2) BACKEND
# ============================================================

class LLMBackend:
    """
    Kombiniert beide vorhandenen Backend-Ideen:
    - echter lokaler Request an /api/generate
    - robuster Dummy-Fallback, falls lokal nichts erreichbar ist
    """

    def __init__(self, base_url: str = "http://localhost:11434", model: str = "llama3.1"):
        self.base_url = base_url.rstrip("/")
        self.model = model

    def _dummy_response(self, prompt: str, n: int) -> List[str]:
        snippet = prompt.strip().replace("\n", " ")[:160]
        return [f"(UP-Dummy-Antwort) {snippet} ..." for _ in range(max(1, n))]

    def generate(self, prompt: str, temperature: float = 0.3, n: int = 1) -> List[str]:
        payload = {
            "model": self.model,
            "prompt": prompt,
            "temperature": temperature,
            "n": n,
        }

        try:
            r = requests.post(f"{self.base_url}/api/generate", json=payload, timeout=60)
            r.raise_for_status()
            data = r.json()

            if isinstance(data, dict):
                if "results" in data and isinstance(data["results"], list):
                    outputs = []
                    for item in data["results"]:
                        if isinstance(item, dict):
                            outputs.append(item.get("text") or item.get("response") or "")
                        else:
                            outputs.append(str(item))
                    return outputs or self._dummy_response(prompt, n)

                if "response" in data:
                    return [str(data["response"])]

                if "text" in data:
                    return [str(data["text"])]

            if isinstance(data, list):
                outputs = []
                for item in data:
                    if isinstance(item, dict):
                        outputs.append(item.get("text") or item.get("response") or "")
                    else:
                        outputs.append(str(item))
                return outputs or self._dummy_response(prompt, n)

        except Exception:
            pass

        return self._dummy_response(prompt, n)


